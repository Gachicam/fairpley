// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth.js 用モデル
// ============================================

model User {
  id            String    @id @default(uuid(7))
  name          String?
  username      String?   // Discord username (@hogehoge)
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(PENDING)

  // 自宅の場所（Shapley計算のデフォルト出発地）
  homeLocationId String?
  homeLocation   Location? @relation("UserHome", fields: [homeLocationId], references: [id], onDelete: SetNull)

  accounts Account[]
  sessions Session[]

  // アプリケーション固有のリレーション
  ownedEvents Event[]       @relation("EventOwner")
  memberships EventMember[]
  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeLocationId])
}

enum UserRole {
  PENDING // 承認待ち
  MEMBER  // 一般メンバー
  ADMIN   // 管理者
}

model Account {
  id                String  @id @default(uuid(7))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid(7))
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// アプリケーションモデル
// ============================================

model Event {
  id               String    @id @default(uuid(7))
  name             String    @db.VarChar(100)
  startDate        DateTime
  endDate          DateTime
  gasPricePerLiter Int       @default(170) // ガソリン単価（円/L）

  // 往路・復路の移動日付と時刻（toll計算用）
  outboundDate  DateTime? // 往路の日付（日付部分のみ使用）
  returnDate    DateTime? // 復路の日付（日付部分のみ使用）
  checkinTime   Int?      // チェックイン時刻（0-1439分）
  checkoutTime  Int?      // チェックアウト時刻（0-1439分）

  ownerId String
  owner   User   @relation("EventOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // 目的地（キャンプ場など）
  destinationId String?
  destination   Location? @relation("EventDestination", fields: [destinationId], references: [id], onDelete: SetNull)

  members       EventMember[]
  payments      Payment[]
  rentalOptions RentalOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([startDate])
  @@index([destinationId])
}

model EventMember {
  id             String  @id @default(uuid(7))
  eventId        String
  userId         String
  nickname       String? @db.VarChar(50)
  loadingMinutes Int     @default(15) // 各経由地での荷積み・荷降ろし時間（分）

  // イベントでの出発地（未設定ならUser.homeLocationを使用）
  departureLocationId String?
  departureLocation   Location? @relation("MemberDeparture", fields: [departureLocationId], references: [id], onDelete: SetNull)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicles             Vehicle[]
  paymentBeneficiaries PaymentBeneficiary[]

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([departureLocationId])
}

model Location {
  id      String       @id @default(uuid(7))
  name    String       @db.VarChar(100)
  address String?      @db.VarChar(200)
  lat     Float
  lng     Float
  type    LocationType

  // リレーション
  usersHome         User[]        @relation("UserHome")
  eventsDestination Event[]       @relation("EventDestination")
  membersDeparture  EventMember[] @relation("MemberDeparture")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LocationType {
  HOME     // 自宅（集合場所）
  CAMPSITE // キャンプ場
  STORE    // 店舗（買い出し）
  OTHER    // その他
}

model Vehicle {
  id             String       @id @default(uuid(7))
  name           String       @db.VarChar(100)
  type           VehicleType
  vehicleClass   VehicleClass @default(STANDARD) // 高速料金計算用の車種区分
  hasEtc         Boolean      @default(true)      // ETC搭載有無
  ownerId        String?
  capacity       Int          @db.SmallInt
  fuelEfficiency Float?

  owner EventMember? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

enum VehicleType {
  OWNED    // 自家用車
  RENTAL   // レンタカー
  CARSHARE // カーシェア
  BIKE     // バイク（Shapley計算から除外）
}

enum VehicleClass {
  LIGHT    // 軽自動車・二輪車
  STANDARD // 普通車
  MEDIUM   // 中型車
  LARGE    // 大型車
  EXTRA    // 特大車
}

model RentalOption {
  id           String @id @default(uuid(7))
  eventId      String
  name         String @db.VarChar(100)
  provider     String @db.VarChar(100)
  baseFee      Int
  distanceFee  Int?
  insuranceFee Int?
  capacity     Int    @db.SmallInt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
}

model Payment {
  id          String  @id @default(uuid(7))
  eventId     String
  payerId     String
  amount      Int
  description String  @db.VarChar(200)
  isTransport Boolean @default(false) // 交通費フラグ（true: Shapley値で分配）

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  payer User  @relation(fields: [payerId], references: [id], onDelete: Cascade)

  beneficiaries PaymentBeneficiary[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([payerId])
}

model PaymentBeneficiary {
  id        String @id @default(uuid(7))
  paymentId String
  memberId  String

  payment Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  member  EventMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([paymentId, memberId])
  @@index([paymentId])
  @@index([memberId])
}
